<div class="row pt-4">
  <div class="col-md-4 offset-md-4 p-4 card shadow-sm">
    <h1 class="text-center mb-4">Log In</h1>
    <%= form_with url: login_path, scope: :user do |form| %>
      <div class="mb-3">
        <%= form.email_field :email, required: true, placeholder: "E-mail address", autofocus: true, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= form.password_field :password, required: true, placeholder: "Password", class: "form-control" %>
      </div>

      <div class="d-flex justify-content-between">
        <div class="form-check mb-3">
          <%= form.check_box :remember_me, class: "form-check-input" %>
          <%= form.label :remember_me, class: "form-check-label" %>
        </div>
        <div>
          <%= link_to "Reset Password", new_password_path %>
        </div>
      </div>

      <div class="d-flex justify-content-between">
        <%= form.submit "Sign In", class: "btn btn-primary" %>
        <%= link_to "Cancel", root_path, class: "btn btn-outline-danger" %>
      </div>
    <% end %>
  </div>
</div>